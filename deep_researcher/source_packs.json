      "{subject} official docs",
      "{subject} official blog",
      "{subject} official report"
    ],
    "source_hints": ["Official docs, blogs, reports, or release notes"],
    "allowed_domains": [],
    "priority_bias": "high",
    "preferred": true,
    "optional": false
  },
  {
